{
    "compilerOptions": {
        "outDir": "./built",
        "allowJs": true,
        "lib": ["ES2020", "DOM"],
        "target": "ES2020",
        "module": "commonjs",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": true
    },
    "include": [
        "./lib/*",
        "./lib/@types"
    ]
}
